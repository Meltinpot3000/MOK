NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_publishable_key
NEXT_PUBLIC_APP_URL=http://localhost:3000
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Server-side only
SUPABASE_DB_PASSWORD=your_db_password
# Optional: Session-Pooler-Host (Dashboard → Connect → Session pooler), z. B. aws-1-eu-west-1.pooler.supabase.com
# Wenn gesetzt und SUPABASE_POOLER_DB_URL / DATABASE_URL fehlen, bauen resolveDatabaseUrl (web) und npm run db:migrate
# die URL aus SUPABASE_DB_PASSWORD + NEXT_PUBLIC_SUPABASE_URL (Project-Ref) + SUPABASE_POOLER_HOST (+ optional SUPABASE_POOLER_PORT, default 5432).
# SUPABASE_POOLER_HOST=aws-1-eu-west-1.pooler.supabase.com
# SUPABASE_POOLER_PORT=5432
# Postgres: Pooler-Benutzer ist postgres.<project_ref> (Supabase Dashboard → Connect).
# Session pooler („Session mode“): Port 5432 — Standard für Migrationen und längere DB-Sessions, z. B.:
#   postgresql://postgres.your-project-ref:your_db_password@aws-1-eu-west-1.pooler.supabase.com:5432/postgres
# Transaction pooler („Transaction mode“): Port 6543 — kurzlebige Transaktionen (anderer Pool).
# Die drei URLs unten nutzen den Session-Pooler (5432). ?sslmode=require ist ok; node-pg für sentinel_map
# normalisiert TLS siehe web/lib/ai/semantic-map/storage/sentinel-map-db.ts.
# Repo-Root: npm run db:migrate laedt .env / .env.local sowie web/.env.local (siehe scripts/run-dbmate.mjs).
SUPABASE_POOLER_DB_URL=postgresql://postgres.your-project-ref:your_db_password@aws-1-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.your-project-ref:your_db_password@aws-1-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require
DIRECT_DATABASE_URL=postgresql://postgres.your-project-ref:your_db_password@aws-1-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require
GEMINI_API_KEY=your_gemini_key
GROQ_API_KEY=your_groq_key
# Optional: OKR Contribution Assessment (LLM) platformweit aus (default an). Wert "false" schaltet hart ab (zusaetzlich zum Tenant-Toggle unter /llm-usage).
# OKR_CONTRIBUTION_ASSESSMENT_ENABLED=false
# Chat/JSON: Groq zuerst, Gemini als Fallback (siehe web/lib/analysis-network/providers.ts).
# Groq llama-3.3-70b hat i. d. R. ~30 RPM / 12k TPM (Kontingent in Groq Console pruefen).
# ANALYSIS_LLM_MIN_INTERVAL_MS_GROQ=250
# ANALYSIS_LLM_MIN_INTERVAL_MS_GEMINI=900
# ANALYSIS_LLM_RETRY_BASE_DELAY_MS_GROQ=800
# ANALYSIS_LLM_RETRY_BASE_DELAY_MS_GEMINI=1200
# Pause zwischen Objective-Bewertungen im Backfill (ms, default 1200):
# ANALYSIS_LLM_OBJECTIVE_EVAL_DELAY_MS=1200
CRON_SECRET=your_cron_secret

# Optional: AI Assistant Smoke (web/scripts/ai-assistant-smoke-complex.mjs)
# AI_SMOKE_SECRET=
# AI_SMOKE_BASE_URL=http://localhost:3000
# AI_SMOKE_USER_EMAIL=
# Preset thomas_maissen setzt org/membership/user + Default-E-Mail (ueberschreibbar mit AI_SMOKE_USER_EMAIL).
# AI_SMOKE_PRESET=thomas_maissen
# AI_SMOKE_QUESTION_SET=strategy_directions
# AI_SMOKE_ORGANIZATION_ID=
# AI_SMOKE_MEMBERSHIP_ID=
# AI_SMOKE_USER_ID=
# AI_SMOKE_FAST_MODE=true
# AI_SMOKE_MODE=preflight
# AI_SMOKE_PREFLIGHT_SKIP_GENERATE=false
# AI_SMOKE_STRICT_EXIT=false
STRATEGY_CYCLE_JOBS_CRON_SECRET=your_strategy_cycle_jobs_secret
# Optional: wie oft der Worker nach einem Enqueue intern per HTTP gekickt wird (1–12, default 4). NEXT_PUBLIC_APP_URL fuer lokale Kicks setzen.
# ANALYSIS_JOB_WORKER_KICK_BURST=4
ANALYSIS_LLM_MODEL_GEMINI_EMBEDDING=text-embedding-004

# Sentinel Assistant: lokales LLM (Ollama). Modell z. B. `ollama pull qwen2.5:3b-instruct`, dann `ollama serve`.
# SENTINEL_LOCAL_LLM_PROVIDER=ollama
# SENTINEL_LOCAL_LLM_BASE_URL=http://localhost:11434
# SENTINEL_LOCAL_LLM_MODEL=qwen2.5:3b-instruct
# SENTINEL_LOCAL_LLM_TIMEOUT_MS=30000

# Optional: Semantic Map — Answer-Verifier ersetzt freie LLM-Antwort bei High-Risk-Evidence-Luecken (z. B. Challenge/Initiative).
# Default: aus. Aktivierung laedt aktive Map, fuehrt Question-Resolution (LLM) aus und prueft Tool-Calls gegen Evidence.
# AI_SEMANTIC_EVIDENCE_GUARD_ENABLED=true
